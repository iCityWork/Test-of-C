{
  "version": "2.0.0",
  "tasks": [

    // ── 1. BUILD + LAUNCH  (Ctrl+Shift+B — default) ───────────
    {
      "label": "Make: Run → Debug + Launch in Atari800MacX",
      "type": "shell",
      "command": "make run",
      "options": { "cwd": "${workspaceFolder}" },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": {
        "owner": "cc65",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+)\\((\\d+)\\):\\s+(Error|Warning|Note):\\s+(.+)$",
          "file": 1, "line": 2, "severity": 3, "message": 4
        }
      },
      "detail": "Debug build + auto-launch in Atari800MacX.  (Ctrl+Shift+B)"
    },

    // ── 2. DEBUG BUILD ONLY — no launch ───────────────────────
    {
      "label": "Make: Debug → Atari 400/800",
